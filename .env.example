APP_ENV=development
APP_NAME=landintel-core
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://landintel:landintel@postgres:5432/landintel
DATABASE_ECHO=false

API_HOST=0.0.0.0
API_PORT=8000

WORKER_ID=worker-local-1
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_ATTEMPTS=3
WORKER_METRICS_PORT=9101

SCHEDULER_POLL_INTERVAL_SECONDS=30

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/data/storage

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=raw-assets
SUPABASE_AUTH_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

SNAPSHOT_HTTP_TIMEOUT_SECONDS=20
RUN_DB_MIGRATIONS=false

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

SENTRY_DSN=

