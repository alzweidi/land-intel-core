APP_ENV=production
APP_NAME=landintel-core
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<db-password>@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
DATABASE_ECHO=false

API_HOST=0.0.0.0
API_PORT=8000

WORKER_ID=worker-prod-1
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_MAX_ATTEMPTS=3
WORKER_METRICS_PORT=9101

SCHEDULER_POLL_INTERVAL_SECONDS=30

STORAGE_BACKEND=supabase
STORAGE_LOCAL_ROOT=/data/storage

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=raw-assets
SUPABASE_AUTH_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

SNAPSHOT_HTTP_TIMEOUT_SECONDS=20
RUN_DB_MIGRATIONS=false
SENTRY_DSN=

API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
BACKEND_BASIC_AUTH_USER=backend-ops
BACKEND_BASIC_AUTH_PASSWORD_HASH=replace-with-caddy-password-hash
